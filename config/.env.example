# Address to listen on
WEBHIX_ADDR=:8080

# Public base URL — used to generate webhook URLs (e.g. https://hooks.example.com)
WEBHIX_BASE_URL=http://localhost:8080

# Path to SQLite data directory
WEBHIX_DB_PATH=./data

# Maximum webhook request body size in bytes (default: 5 MB)
WEBHIX_MAX_BODY_SIZE=5242880

# Maximum number of stored requests per hook (0 = unlimited)
WEBHIX_MAX_REQUESTS=0

# Basic auth password for browser access (optional)
WEBHIX_PASSWORD=

# Secret key for API / CLI access via Bearer token or X-Webhix-Key header (optional)
WEBHIX_SECRET_KEY=

# Comma-separated list of trusted proxy CIDRs (optional, e.g. 10.0.0.0/8)
WEBHIX_TRUSTED_PROXIES=

# Start in read-only mode — disables request capture (default: false)
WEBHIX_READONLY=false
